{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=sistema_epis;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Key": "SISTEMA_EPIS_CHAVE_SUPER_SECRETA_123456789",
    "Issuer": "SistemaEpis",
    "Audience": "SistemaEpisUsers",
    "ExpiresInMinutes": 120
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}